{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "mimo-v2.5-pro",
    "base_url": "https://api.xiaomimimo.com/v1",
    "api_key_env": "MIMO_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "languages": ["zh", "en"],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "claude-code",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "google",
        "repo": "gemma",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/blog/rss.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "The Verge - AI",
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "The Verge - Gaming",
        "url": "https://www.theverge.com/rss/games/index.xml",
        "enabled": true,
        "category": "gaming"
      },
      {
        "name": "IGN",
        "url": "https://feeds.feedburner.com/ign/games-all",
        "enabled": true,
        "category": "gaming"
      },
      {
        "name": "Nintendo Everything",
        "url": "https://nintendoeverything.com/feed/",
        "enabled": true,
        "category": "gaming"
      },
      {
        "name": "Push Square (PlayStation)",
        "url": "https://www.pushsquare.com/feeds/latest",
        "enabled": true,
        "category": "gaming"
      },
      {
        "name": "36kr - AI",
        "url": "https://36kr.com/feed",
        "enabled": true,
        "category": "ai-news-zh"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50
        },
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 30
        },
        {
          "subreddit": "gaming",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        },
        {
          "subreddit": "NintendoSwitch",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 50
        },
        {
          "subreddit": "PS5",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 8,
          "min_score": 50
        },
        {
          "subreddit": "soccer",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        }
      ],
      "users": [],
      "fetch_comments": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 5.5,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "ai": {
        "limit": 10,
        "categories": ["ai-news", "ai-tools", "ai-news-zh", "machine-learning"]
      },
      "gaming": {
        "limit": 6,
        "categories": ["gaming"]
      },
      "sports": {
        "limit": 4,
        "categories": ["sports", "soccer"]
      }
    },
    "default_group": "other",
    "default_group_limit": 5
  },
  "webhook": {
    "enabled": false
  }
}
